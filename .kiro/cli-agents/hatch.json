{
  "description": "Hatch squad member — shared chat + KB over MCP, briefed on the backlog at session start.",
  "hooks": {
    "agentSpawn": [
      {
        "command": "hatch brief --as kiro --format text"
      }
    ],
    "preToolUse": [
      {
        "command": "hatch guard",
        "matcher": "fs_write"
      }
    ]
  },
  "includeMcpJson": true,
  "mcpServers": {
    "hatch": {
      "args": [
        "mcp",
        "--as",
        "kiro"
      ],
      "command": "hatch"
    }
  },
  "name": "hatch"
}
