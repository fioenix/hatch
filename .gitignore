.DS_Store
node_modules/
*.pyc
__pycache__/
promo/

# Go build artifacts (make build / install / test).
/bin/
/hatch
/demo-workspace/
*.out
*.test

# Hatch: only the SSOT under .hatch is committed; everything else (run/, and any
# stray runtime from an old build: bus/, logs/, …) is ignored via this whitelist.
/.hatch/*
!/.hatch/charter.md
!/.hatch/working-agreement.md
!/.hatch/registry.yaml
!/.hatch/workflow.yaml
!/.hatch/roles/
!/.hatch/context/
!/.hatch/kb/
!/.hatch/protocol/
!/.hatch/templates/
