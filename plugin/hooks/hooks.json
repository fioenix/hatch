{
  "description": "SessionStart briefs the agent from the Hatch chat; PreToolUse guards edits to policy-protected files.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hatch brief",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "hatch guard",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
